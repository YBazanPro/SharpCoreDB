{
  "name": "@sharpcoredb/client",
  "version": "1.5.0",
  "description": "TypeScript/JavaScript client for SharpCoreDB Server",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [
    "database",
    "client",
    "grpc",
    "rest",
    "websocket",
    "sharpcoredb",
    "typescript",
    "javascript"
  ],
  "author": "MPCoreDeveloper <mpc@sharpcoredb.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MPCoreDeveloper/SharpCoreDB",
    "directory": "clients/javascript/sharpcoredb-client"
  },
  "bugs": {
    "url": "https://github.com/MPCoreDeveloper/SharpCoreDB/issues"
  },
  "homepage": "https://sharpcoredb.com/docs/js-client",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.0",
    "@grpc/proto-loader": "^0.7.0",
    "axios": "^1.6.0",
    "ws": "^8.14.0",
    "google-protobuf": "^3.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^7.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@types/node": ">=16.0.0"
  },
  "peerDependenciesMeta": {
    "@types/node": {
      "optional": true
    }
  }
}
