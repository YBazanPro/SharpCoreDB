{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Grpc": "Information"
    }
  },
  "AllowedHosts": "*",
  "Server": {
    "ServerName": "SharpCoreDB Server (Development)",
    "BindAddress": "0.0.0.0",
    "GrpcPort": 5001,
    "EnableGrpc": true,
    "EnableHttpsApi": true,
    "HttpsApiPort": 8443,
    "MaxConnections": 1000,
    "ConnectionTimeoutSeconds": 300,
    "DefaultDatabase": "master",
    "Databases": [
      {
        "Name": "master",
        "DatabasePath": "./data/system/master.scdb",
        "StorageMode": "SingleFile",
        "EncryptionEnabled": true,
        "EncryptionKeyFile": "./secrets/master.key",
        "ConnectionPoolSize": 25,
        "IsSystemDatabase": true,
        "IsReadOnly": false
      },
      {
        "Name": "model",
        "DatabasePath": "./data/system/model.scdb",
        "StorageMode": "SingleFile",
        "EncryptionEnabled": true,
        "EncryptionKeyFile": "./secrets/model.key",
        "ConnectionPoolSize": 10,
        "IsSystemDatabase": true,
        "IsReadOnly": true
      },
      {
        "Name": "msdb",
        "DatabasePath": "./data/system/msdb.scdb",
        "StorageMode": "SingleFile",
        "EncryptionEnabled": true,
        "EncryptionKeyFile": "./secrets/msdb.key",
        "ConnectionPoolSize": 10,
        "IsSystemDatabase": true,
        "IsReadOnly": false
      },
      {
        "Name": "tempdb",
        "DatabasePath": "./data/system/tempdb.scdb",
        "StorageMode": "SingleFile",
        "EncryptionEnabled": false,
        "EncryptionKeyFile": null,
        "ConnectionPoolSize": 10,
        "IsSystemDatabase": true,
        "IsReadOnly": false
      },
      {
        "Name": "appdb",
        "DatabasePath": "./data/user/appdb.scdb",
        "StorageMode": "SingleFile",
        "EncryptionEnabled": true,
        "EncryptionKeyFile": "./secrets/appdb.key",
        "ConnectionPoolSize": 50,
        "IsSystemDatabase": false,
        "IsReadOnly": false
      }
    ],
    "SystemDatabases": {
      "Enabled": true,
      "MasterDatabaseName": "master",
      "ModelDatabaseName": "model",
      "MsdbDatabaseName": "msdb",
      "TempDbDatabaseName": "tempdb"
    },
    "Security": {
      "RequireAuthentication": true,
      "AuthMethods": [ "jwt", "certificate" ],
      "JwtSecret": null,
      "JwtExpirationMinutes": 60,
      "TlsEnabled": true,
      "TlsCertificatePath": "./certs/server.pfx",
      "TlsPrivateKeyPath": null,
      "RequireClientCertificate": false,
      "MinimumTlsVersion": "Tls12"
    },
    "Logging": {
      "Level": "Information",
      "FilePath": "./logs/sharpcoredb-server.log",
      "MaxFileSizeMB": 100,
      "MaxFiles": 10,
      "LogQueries": false,
      "LogSlowQueries": true,
      "SlowQueryThresholdMs": 1000
    },
    "Performance": {
      "QueryCacheSizeMB": 256,
      "EnableQueryPlanCache": true,
      "WorkerThreads": 0,
      "EnableMetrics": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Grpc": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithThreadId", "WithMachineName" ]
  }
}
